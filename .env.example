# Flask (BẮT BUỘC đổi thành chuỗi ngẫu nhiên khi deploy production)
FLASK_SECRET=kg2m-change-this-in-production

# Ollama (LLM tự host)
# URL gốc của Ollama server (không có /api/generate ở cuối)
OLLAMA_BASE_URL=https://your-ollama-server/ollama
OLLAMA_MODEL=gemma4:26b

